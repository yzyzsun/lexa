effectz Hello {
    dcl hello: () -> int
}

def run [;] (): int {
    val s = newref {42};
    handle <> {
        raise hello_l.hello() 
    } with hello_l: Hello {
        def hello() { 
            ~strPrint("hello\n");
            ~printInt(s[0]);
            0
        }        
    }
}

def main [;] (): int {
    run()
}