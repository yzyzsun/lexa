type list::['a] = 
    | Nil
    | Cons of 'a * list::['a]

def make(x: int): list::[int] {
    if x == 0 then Nil::[int]
    else Cons::[int] (x, make(x - 1))
}

def print_list(l: list::[int]): unit {
    match l with
    | Nil -> { () }
    | Cons (h, t) -> {
        ~printInt(h);
        print_list(t)
    }
}

def map::['a, 'b] (f: <> ('a) -> 'b, l: list::['a]): list::['b] {
    match l with
    | Nil -> { Nil::['b] }
    | Cons (h, t) -> {
        Cons::['b] (f(h), map::['a, 'b] (f, t))
    }
}

def append::['a] (l1: list::['a], l2: list::['a]): list::['a] {
    match l1 with
    | Nil -> { l2 }
    | Cons (h, t) -> {
        Cons::['a] (h, append::['a](t, l2))
    }
}

def main(): int {
    val l1 = make(~readInt());
    val l2 = make(~readInt());

    val ll = map::[int, int](fun <> (x: int): int { x * 2 }, append::[int](l1, l2));
    print_list(ll);
    0
}