type tree::['a] = 
    | Leaf
    | Node of 'a * tree::['a] * tree::['a]

def make_tree(i: int): tree::[int] {
    if i == 0 then
        Leaf::[int]()
    else
        Node::[int](i, make_tree(i - 1), make_tree(i - 1))
}

def traverse(t: tree::[int]): unit {
    match t with
    | Leaf -> {
        ()
    }
    | Node (i, l, r) -> {
        ~printInt(i);
        traverse(l);
        traverse(r);
        ()
    }
}