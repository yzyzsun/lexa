type tree::['a] = 
    | Leaf
    | Node of 'a * tree::['a] * tree::['a]

def main(): int {
    val t = make(~readInt());
    traverse(t);
    0
}

def make(i: int): tree::[int] {
    if i == 0 then
        Leaf::[int]()
    else
        Node::[int](i, make(i - 1), make(i - 1))
}

def traverse(t: tree::[int]): unit {
    match t with
    | Leaf -> {
        ()
    }
    | Node (i, l, r) -> {
        ~printInt(i);
        traverse(l);
        traverse(r);
        ()
    }
}