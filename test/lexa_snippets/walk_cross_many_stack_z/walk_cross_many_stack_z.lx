exceptional effect E1 {
    op1: () -> int
}

exceptional effect E2 {
    op2: () -> int
}

exceptional effect E3 {
    op3: () -> int
}

exceptional effect E4 {
    op4: () -> int
}

exceptional effect E5 {
    op5: () -> int
}

def main [;] (): int {
    handle <> {
        handle <e5> {
            handle <e4, e5> {
                handle <e3, e4, e5> {
                    handle <e2, e3, e4, e5> {
                        ~printInt(raise e5.op5());
                        ~printInt(raise e4.op4());
                        ~printInt(raise e3.op3());
                        ~printInt(raise e2.op2());
                        ~printInt(raise e1.op1());
                        0
                    } with e1: E1 {
                        hdl_1 op1(k) {
                            ~printInt(1);
                            resume_final k 1;
                            0
                        }
                    };
                    0
                } with e2: E2 {
                    hdl_1 op2(k) {
                        ~printInt(2);
                        resume_final k 2;
                        0
                    }
                };
                0
            } with e3: E3 {
                hdl_1 op3(k) {
                    ~printInt(3);
                    resume_final k 3;
                    0
                }
            };
            0
        } with e4: E4 {
            hdl_1 op4(k) {
                ~printInt(4);
                resume_final k 4;
                0
            }
        }
    } with e5: E5 {
        def op5() {
            ~printInt(5);
            5
        }
    }
}
