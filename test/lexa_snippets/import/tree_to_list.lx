open "../adt/lib_list.lx"
open "../adt/lib_tree.lx"

def main(): int {
    val example = Node::[int](4, 
        Node::[int](3, 
            Node::[int](2, Leaf::[int], Leaf::[int]), 
            Node::[int](1, Leaf::[int], Leaf::[int])), 
        Node::[int](5, Leaf::[int], Leaf::[int]));
    print_list(explore(example, Nil::[int]));
    0
}


def explore(tre: tree::[int], acc: list::[int]): list::[int] {
    match tre with
    | Leaf -> { acc }
    | Node (value, left, right) -> {
        val acc1 = explore(left, acc);
        val acc2 = explore(right, acc);
        append::[int](acc1, Cons::[int] (value, acc2))
    }
}