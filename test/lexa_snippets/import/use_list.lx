open "../adt/lib_list.lx"

def main(): int {
    val example = Cons::[list::[int]](make(3), 
                    Cons::[list::[int]](make(2), 
                        Cons::[list::[int]](make(1), Nil::[list::[int]])));
    map::[list::[int], unit](fun <> (x: list::[int]): unit {print_list(x)}, example);
    0
}
