effect Hello {
    hello: () -> int
}

def run(): int {
    val s = newref {42};
    handle <> {
        raise hello_stub.hello() 
    } with hello_stub: Hello {
        def hello() { 
            ~strPrint("hello\n");
            ~printInt(s[0]);
            0
        }        
    }
}

def main(): int {
    run()
}
