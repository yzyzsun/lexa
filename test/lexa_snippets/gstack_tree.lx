effect Choose {
    choose: (int, tree, tree) -> tree
}

type tree = 
    | Leaf
    | Node of int * tree * tree

def make(n: int): tree {
    if n == 0 then
        Leaf
    else
        val t = make(n - 1);
        Node(n, t, t)
}

def traverse [; choose_l: Choose] (tr: tree): int {
    match tr with
    | Leaf -> { 0 }
    | Node(v, l, r) -> { 
        traverse:[; choose_l](raise choose_l.choose(v, l, r))
    }
}

def main(): int {
    val n = ~readInt();
    val tr = make(n);

    val res = handle <> {
        traverse:[; choose_l](tr)
    } with choose_l: Choose {
        hdl_s choose(v, l, r, k) {
            v + resume k l + resume k r
        }
    };
    ~printInt(res);
    0
}