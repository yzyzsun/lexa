effect Choose {
    choose: (ref int) -> int
}

def main(): int {
    val x = ~readInt();
    ~printInt(f(x));
    0 
}

def f(x: int): int {
    handle <> {
        handle <left_stub> {
            val p = newref {10,20};
            if x == 1 then
                raise left_stub.choose(p)
            else
                raise right_stub.choose(p)
        } with right_stub: Choose {
            def choose(p) {
                p[1]
            }            
        }
    } with left_stub: Choose {
        def choose(p) {
            p[0]
        }
    }
}
