def f(x: int): int {
    rec def p <> (x: int, i: int): int {
        if x == 0 then 
            val _ = ~printInt(i);
            ~printInt(x)
        else
            val _ = ~printInt(i);
            val _ = ~printInt(x);
            p(x - 1, i + 1)
    };
    p(x, 0)
}

def main(): int {
    val _ = f(~readInt());
    0
}