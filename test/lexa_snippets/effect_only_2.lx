effect E {
    plus_42: (int) -> int
}

def f(): int {
    val x = newref {0};
    x[0] := x[0] + 42;
    x[0]
}

def g(): int {
    val x = newref {0};
    handle <> {
        x[0] := raise e_stub.plus_42(x[0])
    } with e_stub : E {
        def plus_42(y) {
            y + 42
        }
    };
    x[0]
}

def main(): int {
    ~printInt(f());
    ~printInt(g());
    0
}