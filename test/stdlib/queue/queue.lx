open "../../../stdlib/assert.lx"
open "../../../stdlib/queue.lx"

def test_queue(): int {
    val q = queue_make::[int]();
    queue_enqueue::[int](q, 1);
    queue_enqueue::[int](q, 2);

    queue_enqueue::[int](q, 3);

    assert(queue_dequeue::[int](q) == 1);
    assert(queue_peek::[int](q) == 2);
    assert(queue_dequeue::[int](q) == 2);
    assert(queue_dequeue::[int](q) == 3);
    assert(queue_is_empty::[int](q));
    0
}

def main(): int {
    test_queue();
    ~strPrint("OK");
    0
}