open "../../../stdlib/assert.lx"
open "../../../stdlib/option.lx"

def test_option_get_success(): unit {
    assert(option_get::[int] (Some::[int](3)) == 3)
}

def test_option_bind(): unit {
    assert(option_get::[int] (option_bind::[int, int](
        Some::[int](3), 
        fun <> (x: int): option::[int] { Some::[int](x + 1) }
    )) == 4);

    assert(is_none::[int](option_bind::[int, int](
        Some::[int](3), 
        fun <> (_: int): option::[int] { None::[int] }
    )));

    assert(is_none::[int](option_bind::[int, int](
        None::[int], 
        fun <> (x: int): option::[int] { Some::[int](x + 1) }
    )))
}

def test_option_map(): unit {
    assert(option_get::[int](option_map::[int, int](Some::[int](3), fun <> (x: int): int { x + 1 })) == 4);
    assert(is_none::[int](option_map::[int, int](None::[int], fun <> (x: int): int { x + 1 })))
}

def test_is_none(): unit {
    assert(is_none::[int](None::[int]));
    assert(!is_none::[int](Some::[int](2)))
}

def test_is_some(): unit {
    assert(!is_some::[int](None::[int]));
    assert(is_some::[int](Some::[int](2)))
}

def main(): int {
    test_option_get_success();
    test_option_bind();
    test_option_map();
    test_is_none();
    test_is_some();
    ~strPrint("OK");
    0
}