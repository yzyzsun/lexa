open "../../../stdlib/assert.lx"
open "../../../stdlib/list.lx"
open "../../../stdlib/option.lx"
open "../../../stdlib/pair.lx"

def test_list_eq_prim(): unit {
    val l1 = Cons::[int](1, Cons::[int](2, Nil::[int]));
    val l2 = Cons::[int](1, Cons::[int](2, Cons::[int](3, Nil::[int])));
    assert(list_eq_prim::[int] (l1, Cons::[int](1, Cons::[int](2, Nil::[int]))));
    assert(!list_eq_prim::[int] (l1, l2));
    assert(!list_eq_prim::[int] (l1, Nil::[int]));
    assert(list_eq_prim::[int] (Nil::[int], Nil::[int]))
}

def test_list_eq(): unit {
    val l1 = Cons::[pair::[int, int]]
        (Pair::[int, int](1, 2), 
        Cons::[pair::[int, int]](
            Pair::[int, int](3, 4), 
            Nil::[pair::[int, int]]
        )
    );
    assert(list_eq::[pair::[int, int]] (pair_eq_prim::[int, int], l1, 
        Cons::[pair::[int, int]](
            Pair::[int, int](1, 2), 
            Cons::[pair::[int, int]](
                Pair::[int, int](3, 4), 
                Nil::[pair::[int, int]]
            )
        )
    ));
    assert(!list_eq::[pair::[int, int]] (pair_eq_prim::[int, int], l1, Cons::[pair::[int, int]](Pair::[int, int](2, 3), Nil::[pair::[int, int]])))
}

def test_list_length(): unit {
    assert(list_length::[int](Nil::[int]) == 0);
    assert(list_length::[int](Cons::[int](1, Cons::[int](2, Nil::[int]))) == 2)
}

def test_nth(): unit {
    assert(nth::[int](Cons::[int](1, Cons::[int](2, Cons::[int](3, Nil::[int]))), 1) == 2);
    assert(nth::[int](Cons::[int](1, Cons::[int](2, Cons::[int](3, Nil::[int]))), 2) == 3)
}

def test_nth_opt(): unit {
    assert(option_get::[int](nth_opt::[int](Cons::[int](1, Cons::[int](2, Cons::[int](3, Nil::[int]))), 1)) == 2);
    assert(is_none::[int](nth_opt::[int](Cons::[int](1, Cons::[int](2, Cons::[int](3, Nil::[int]))), 3)))
}

def test_hd_opt(): unit {
    assert(option_get::[int](hd_opt::[int](Cons::[int](1, Cons::[int](2, Nil::[int])))) == 1);
    assert(is_none::[int](hd_opt::[int](Nil::[int])))
}

def test_tl_opt(): unit {
    assert(hd::[int](option_get::[list::[int]](tl_opt::[int](Cons::[int](1, Cons::[int](2, Nil::[int]))))) == 2);
    assert(is_none::[list::[int]](tl_opt::[int](Nil::[int])))
}

def test_zip(): unit {
    val l1 = Cons::[int](1, Cons::[int](3, Cons::[int](5, Nil::[int])));
    val l2 = Cons::[int](2, Cons::[int](4, Cons::[int](6, Nil::[int])));
    val out = zip::[int, int](l1, l2);
    val out1 = hd::[pair::[int, int]](out);
    val out2 = nth::[pair::[int, int]](out, 1);
    val out3 = nth::[pair::[int, int]](out, 2);
    assert(fst::[int, int](out1) == 1);
    assert(snd::[int, int](out1) == 2);
    assert(fst::[int, int](out2) == 3);
    assert(snd::[int, int](out2) == 4);
    assert(fst::[int, int](out3) == 5);
    assert(snd::[int, int](out3) == 6)
}

def test_list_map(): unit {
    val f = fun <> (x: int): int {x + 1};
    assert(list_eq_prim::[int](
        list_map::[int, int](f, Cons::[int](1, Cons::[int](2, Nil::[int]))),
        Cons::[int](2, Cons::[int](3, Nil::[int])))
    );
    assert(list_eq_prim::[int](
        list_map::[int, int](f, Nil::[int]),
        Nil::[int]
    ))
}

def test_list_mapi(): unit {
    val f = fun <> (i: int, x: int): int {x + i};
    assert(list_eq_prim::[int](
        list_mapi::[int, int](f, Cons::[int](1, Cons::[int](2, Nil::[int]))),
        Cons::[int](1, Cons::[int](3, Nil::[int])))
    );
    assert(list_eq_prim::[int](
        list_mapi::[int, int](f, Nil::[int]),
        Nil::[int]
    ))
}

def test_list_range(): unit {
    assert(list_eq_prim::[int](
        list_range(2,4),
        Cons::[int](2, Cons::[int](3, Cons::[int](4, Nil::[int])))
    ));
    assert(list_eq_prim::[int](
        list_range(2,2),
        Cons::[int](2, Nil::[int])
    ))
}

def test_list_append(): unit {
    assert(list_eq_prim::[int](
        list_append::[int](
            Cons::[int](1, Cons::[int](2, Nil::[int])),
            Cons::[int](3, Cons::[int](4, Nil::[int]))),
        Cons::[int](1, Cons::[int](2, Cons::[int](3, Cons::[int](4, Nil::[int]))))
    ));
    assert(list_eq_prim::[int](
        list_append::[int](
            Nil::[int], 
            Cons::[int](3, Cons::[int](4, Nil::[int]))),
        Cons::[int](3, Cons::[int](4, Nil::[int]))
    ));
    assert(list_eq_prim::[int](
        list_append::[int](
            Cons::[int](1, Cons::[int](2, Nil::[int])), 
            Nil::[int]),
        Cons::[int](1, Cons::[int](2, Nil::[int]))
    ))
}

def test_list_intersection(): unit {
    assert(list_eq_prim::[int](
        list_intersection::[int](
            Cons::[int](1, Cons::[int](2, Nil::[int])), 
            Cons::[int](1, Cons::[int](2, Nil::[int]))),
        Cons::[int](1, Cons::[int](2, Nil::[int]))
    ));
    assert(list_eq_prim::[int](
        list_intersection::[int](
            Cons::[int](3, Cons::[int](4, Nil::[int])), 
            Cons::[int](1, Cons::[int](2, Nil::[int]))),
        Nil::[int]
    ))
}

def test_list_subtract(): unit {
    assert(list_eq_prim::[int](
        list_subtract::[int](
            Cons::[int](1, Cons::[int](2, Nil::[int])), 
            Cons::[int](1, Cons::[int](2, Nil::[int]))),
        Nil::[int]
    ));
    assert(list_eq_prim::[int](
        list_subtract::[int](
            Cons::[int](3, Cons::[int](4, Nil::[int])), 
            Cons::[int](1, Cons::[int](2, Nil::[int]))),
        Cons::[int](3, Cons::[int](4, Nil::[int]))
    ))
}

def test_assoc_list_mem(): unit {
    assert(assoc_list_mem::[int, int](
        Cons::[pair::[int, int]](Pair::[int, int](0,2), 
            Cons::[pair::[int, int]](Pair::[int, int](1,4), 
                Nil::[pair::[int, int]])), 
        0
    ));
    assert(!assoc_list_mem::[int, int](
        Cons::[pair::[int, int]](Pair::[int, int](0,2), 
            Cons::[pair::[int, int]](Pair::[int, int](1,4), 
                Nil::[pair::[int, int]])), 
        2
    ))
}

def test_assoc_list_get_opt(): unit {
    assert(option_get::[int](
        assoc_list_get_opt::[int, int](
            Cons::[pair::[int, int]](Pair::[int, int](0,2),
                Cons::[pair::[int, int]](Pair::[int, int](1,4),
                    Nil::[pair::[int, int]])),
            0)) == 2);
    assert(is_none::[int](
        assoc_list_get_opt::[int, int](
            Cons::[pair::[int, int]](Pair::[int, int](0,2),
                Cons::[pair::[int, int]](Pair::[int, int](1,4),
                    Nil::[pair::[int, int]]))
            , 2)))
}

def test_assoc_list_get_or_default(): unit {
    assert(assoc_list_get_or_default::[int, int](
        Cons::[pair::[int, int]](Pair::[int, int](0,2), 
            Cons::[pair::[int, int]](Pair::[int, int](1,4), 
                Nil::[pair::[int, int]])), 
        0, 4) == 2);
    assert(assoc_list_get_or_default::[int, int](
        Cons::[pair::[int, int]](Pair::[int, int](0,2), 
            Cons::[pair::[int, int]](Pair::[int, int](1,4), 
                Nil::[pair::[int, int]])), 
        2, 5) == 5)
}

def test_assoc_list_set(): unit {
    assert(option_get::[int](
        assoc_list_get_opt::[int, int](
            assoc_list_set::[int, int](
                Cons::[pair::[int, int]](Pair::[int, int](0,2), 
                    Cons::[pair::[int, int]](Pair::[int, int](1,4),
                        Nil::[pair::[int, int]])),
                0, 3), 0)
    ) == 3);
    assert(option_get::[int](
        assoc_list_get_opt::[int, int](
            assoc_list_set::[int, int](
                Cons::[pair::[int, int]](Pair::[int, int](0,2),
                    Cons::[pair::[int, int]](Pair::[int, int](1,4),
                        Nil::[pair::[int, int]])), 
                2, 3), 2)
    ) == 3)
}

def test_assoc_list_dom(): unit {
    assert(list_eq_prim::[int](
        assoc_list_dom::[int, int](
            Cons::[pair::[int, int]](Pair::[int, int](0,2), 
                Cons::[pair::[int, int]](Pair::[int, int](1,4), 
                    Nil::[pair::[int, int]]))),
        Cons::[int](0, Cons::[int](1, Nil::[int]))
    ));
    assert(list_eq_prim::[int](
        assoc_list_dom::[int, int](Nil::[pair::[int, int]]),
        Nil::[int]
    ))
}

def test_assoc_list_vals(): unit {
    assert(list_eq_prim::[int](
        assoc_list_vals::[int, int](
            Cons::[pair::[int, int]](Pair::[int, int](0,2), 
                Cons::[pair::[int, int]](Pair::[int, int](1,4), 
                    Nil::[pair::[int, int]]))),
        Cons::[int](2, Cons::[int](4, Nil::[int]))
    ));
    assert(list_eq_prim::[int](
        assoc_list_vals::[int, int](Nil::[pair::[int, int]]),
        Nil::[int]
    ))
}

def main(): int {
    test_list_eq_prim();
    test_list_eq();
    test_list_length();
    test_nth();
    test_nth_opt();
    test_hd_opt();
    test_tl_opt();
    test_zip();
    test_list_map();
    test_list_mapi();
    test_list_range();
    test_list_append();
    test_list_intersection();
    test_list_subtract();

    test_assoc_list_mem();
    test_assoc_list_get_opt();
    test_assoc_list_get_or_default();
    test_assoc_list_set();
    test_assoc_list_dom();
    test_assoc_list_vals();
    
    ~strPrint("OK");
    0
}