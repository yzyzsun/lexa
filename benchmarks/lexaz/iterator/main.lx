effectz Emit {
    dcl emit: (int) -> unit
}

def range [; emit_l: Emit] (l: int, u: int): int {
    if l > u then
        0
    else (
        raise emit_l.emit(l);
        range:[; emit_l](l + 1, u)
    )
}

def run(n: int): int {
    val s = newref {0};
    handle <> {
        range:[; emit_l](0, n)
    } with emit_l: Emit {
        def emit(e) {
            s[0] := s[0] + e;
            0
        }        
    };
    s[0]
}

def main(): int {
    ~printInt(run(~readInt()));
    0
}