effectz Choice {
    dcl flip: () -> int
    dcl fail: () -> int
}

def choice [; choice_l: Choice](n: int): int {
    if n < 1 then
        raise choice_l.fail()
    else
        if raise choice_l.flip() > 0 then
            n
        else
            choice:[; choice_l](n - 1)
}

def triple [; choice_l: Choice] (n: int, s: int): int {
    val i = choice:[; choice_l](n);
    val j = choice:[; choice_l](i - 1);
    val k = choice:[; choice_l](j - 1);
    if i + j + k == s then
        hash(i, j, k)
    else
        raise choice_l.fail()
}

def run(n: int, s: int): int {
    handle <> {
        triple:[; choice_l](n, s)
    } with choice_l: Choice {
        exc fail() {
            0
        }

        hdl_s flip(k) {
            (resume k 1 + resume_final k 0) % 1000000007
        }
    }
}

def hash(a: int, b: int, c: int): int {
    (53 * a + 2809 * b + 148877 * c) % 1000000007
}

def main(): int {
    val n = ~readInt();
    val res = run(n, n);
    ~printInt(res);
    0
}

