effect Stop {
    stop: ({ z: int | z >= 0 }) -> int
}

def zero(): { z: int | z >= 0 } {
    0
}

def main(): { z: int | z >= 0 } {
    val counter = newref {zero()};
    handle <> { [r, e] =>
        val n = counter[0];
        counter[0] := n + 1;
        raise stop.stop[0; []](counter[0])
    } with stop: Stop {
        exc stop(n) {
            n
        }
    }
}
