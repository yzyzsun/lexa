effect Guard {
    reject: ({ b: bool | b == false }) -> int
}

def main(): { z: int | z == 0 } {
    handle <> { [r, e] =>
        if false then
            1
        else
            raise guard.reject[0; []](false)
    } with guard: Guard {
        exc reject(failed) {
            (fun <> (): { z: int | z == 0 } {
                0
            })()
        }
    }
}
