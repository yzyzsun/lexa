effect Choice {
    flip: () -> int
}

def main(): { z: int | z >= 0 } {
    handle <> { [r, e] =>
        raise choice.flip[0; []]()
    } with choice: Choice {
        hdl_s flip(k) {
            resume k 1;
            resume_final k 0;
            (fun <> (): { z: int | z >= 0 } {
                1
            })()
        }
    }
}
