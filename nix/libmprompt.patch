-mp_resume_t* mp_resume_dup(mp_resume_t* resume) {
-  mp_mresume_t* r = mp_resume_is_multi(resume);
-  if (mp_unlikely(r == NULL)) {
-    mp_error_message(EINVAL, "cannot dup once-resumptions; use 'mp_myield' instead.\n");    
-    return NULL;
-  }
-  else {
-    mp_mresume_dup(r);
-    return resume;
-  }
