-void mp_resume_drop(mp_resume_t* resume) {
-  mp_prompt_t* p = mp_resume_is_once(resume);
-  if (mp_unlikely(p == NULL)) return mp_mresume_drop(mp_resume_is_multi(resume));
-  mp_prompt_drop(p);
-}
