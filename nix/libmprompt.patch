-  mov     rax, [r11+8]      ; return rsp
-  push    rax               
-  push    rdx               ; stack commit limit (field:EFLAGS)
-  push    r8                ; stack reserved     (field:CS)
-  mov     rax, [r11]        ; return rip
-  push    rax
-  push    r9                ; return point (field:error code)
