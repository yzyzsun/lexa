-mp_setjmp ENDP
-
-
-; void  mp_longjmp(mp_jmpbuf_t* jmpbuf);
-; rcx: jmpbuf 
-mp_longjmp PROC
-
-  mov     r11,   [rcx]         ; load rip in r11
-  mov     rsp,   [rcx+8]       ; restore rsp
-    
-  mov     rbx,   [rcx+16]      ; restore registers 
-  mov     rbp,   [rcx+24]
-  mov     rsi,   [rcx+32]  
-  mov     rdi,   [rcx+40]
-  mov     r12,   [rcx+48]
-  mov     r13,   [rcx+56]
-  mov     r14,   [rcx+64]
-  mov     r15,   [rcx+72]
-  
