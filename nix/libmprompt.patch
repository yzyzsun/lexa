-
-//------------------------------------------------------
-// Compiler specific attributes
-//------------------------------------------------------
-
-#if defined(_MSC_VER) || defined(__MINGW32__)
-#if !defined(MP_SHARED_LIB)
-#define mpe_decl_export     
-#elif defined(MP_SHARED_LIB_EXPORT)
